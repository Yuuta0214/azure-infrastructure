# ==========================================
# Docker Compose 構成定義 (Jinja2 Template)
# ==========================================
services:
  # 1. DB層 (MySQL)
  db:
    image: mysql:8.0
    restart: always
    environment:
      # 【修正】Ansible 変数から注入。デフォルト値を設定しつつ秘匿性を確保します
      MYSQL_ROOT_PASSWORD: "{{ mysql_root_password | default('password123') }}"
      MYSQL_DATABASE: "{{ mysql_db_name | default('myapp_db') }}"
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - backend-nw

  # 2. App層 (現在は Nginx ですが、将来のアプリ配置用)
  app:
    image: nginx:latest
    restart: always
    depends_on:
      - db
    networks:
      - frontend-nw
      - backend-nw

  # 3. Web層 (外部からの受付窓口)
  web:
    image: nginx:latest
    restart: always
    ports:
      - "80:80"
    depends_on:
      - app
    networks:
      - frontend-nw

# --- ネットワーク定義 ---
networks:
  frontend-nw:
    driver: bridge
  backend-nw:
    driver: bridge

# --- ボリューム定義 ---
volumes:
  db_data:
services:
  # 1. DBеұӨ
  db:
    image: mysql:8.0
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: password123
      MYSQL_DATABASE: myapp_db
    volumes:
      - db_data:/var/lib/mysql

  # 2. AppеұӨ
  app:
    image: nginx:latest # з–ҺйҖҡзўәиӘҚз”Ё
    restart: always
    depends_on:
      - db

  # 3. WebеұӨ
  web:
    image: nginx:latest
    restart: always
    ports:
      - "80:80"
    depends_on:
      - app

volumes:
  db_data: